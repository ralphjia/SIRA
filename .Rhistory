library(SIRA)
set.seed(1)
d1 <- d2 <- d3 <- 10L
V  <- d1 * d2 * d3
n  <- 50L
beta_true        <- numeric(V)
beta_true[1:27]  <- 3   # small cube near the origin
X <- matrix(rnorm(n), ncol = 1)
Z <- cbind(1, rnorm(n))
Y <- X %*% t(beta_true) +
Z %*% matrix(rnorm(2 * V), nrow = 2) +
matrix(rnorm(n * V, sd = 3), nrow = n)
fit <- sira(Y = Y, X = X, Z = Z,
d1 = d1, d2 = d2, d3 = d3,
lambda = 0.3, mu = 0.1)
?BayesGPfit::GP.eigen.value
