library(SIRA)
set.seed(1)
d1 <- d2 <- d3 <- 10L
V  <- d1 * d2 * d3
n  <- 50L
beta_true        <- numeric(V)
beta_true[1:27]  <- 3   # small cube near the origin
X <- matrix(rnorm(n), ncol = 1)
Z <- cbind(1, rnorm(n))
Y <- X %*% t(beta_true) +
Z %*% matrix(rnorm(2 * V), nrow = 2) +
matrix(rnorm(n * V, sd = 3), nrow = n)
fit <- sira(Y = Y, X = X, Z = Z,
d1 = d1, d2 = d2, d3 = d3,
lambda = 0.3, mu = 0.1)
print(fit)
# Which voxels were recovered?
recovered <- which(fit$betahat[1, ] != 0)
# True signal voxels (the 3x3x3 cube near the origin in column-major order)
true_voxels <- which(beta_true != 0)
cat("Recovered:", sort(recovered), "\n")
cat("True:     ", sort(true_voxels), "\n")
cat("Overlap:  ", length(intersect(recovered, true_voxels)), "of", length(true_voxels), "\n")
cat("False positives:", length(setdiff(recovered, true_voxels)), "\n")
library(SIRA)
set.seed(42)
d1 <- d2 <- d3 <- 10L
V  <- d1 * d2 * d3
n  <- 200L
# Helper: linear voxel indices for a 3D box in column-major order
box <- function(i1r, i2r, i3r) {
as.integer(unlist(lapply(i3r, function(k)
unlist(lapply(i2r, function(j)
i1r + d1 * (j - 1L) + d1 * d2 * (k - 1L))))))
}
# --- True coefficient images -------------------------------------------
# Beta 1: positive cube near (1,1,1),  negative cube near (8,8,8)
# Beta 2: positive cube near (1,8,1),  negative cube near (8,1,8)
# Regions are fully separated (minimum gap >=4 voxels on every axis).
regions <- list(
b1_pos = list(vox = box(1:3, 1:3, 1:3), val =  2.5),
b1_neg = list(vox = box(8:10, 8:10, 8:10), val = -2.5),
b2_pos = list(vox = box(1:3, 8:10, 1:3), val =  2.0),
b2_neg = list(vox = box(8:10, 1:3, 8:10), val = -2.0)
)
beta_true <- matrix(0, nrow = 2, ncol = V)
beta_true[1, regions$b1_pos$vox] <-  2.5
beta_true[1, regions$b1_neg$vox] <- -2.5
beta_true[2, regions$b2_pos$vox] <-  2.0
beta_true[2, regions$b2_neg$vox] <- -2.0
# --- Generate data -------------------------------------------------------
X <- matrix(rnorm(n * 2), ncol = 2)
Z <- cbind(1, rnorm(n))
Y <- X %*% beta_true +
Z %*% matrix(rnorm(2 * V), nrow = 2) +
matrix(rnorm(n * V, sd = 2), nrow = n)
# --- Fit -----------------------------------------------------------------
fit <- sira(Y = Y, X = X, Z = Z,
d1 = d1, d2 = d2, d3 = d3,
lambda = 0.3, mu = 0.1)
print(fit)
# --- Diagnostics ---------------------------------------------------------
cat("\n=== Region-level diagnostics ===\n")
check_covariate <- function(j, true_pos, true_neg) {
bhat      <- fit$betahat[j, ]
recovered <- which(bhat != 0)
pos_rec   <- recovered[bhat[recovered] > 0]
neg_rec   <- recovered[bhat[recovered] < 0]
all_true  <- c(true_pos, true_neg)
cat(sprintf("\nCovariate %d:\n", j))
cat(sprintf("  Regions found   : %d  (expected 2)\n",
length(fit$region_list[[j]])))
cat(sprintf("  Positive region : %d voxels recovered, mean beta = %.3f",
length(pos_rec),
if (length(pos_rec) > 0) mean(bhat[pos_rec]) else NA))
cat(sprintf("  (true: %d voxels, beta = %.1f)\n",
length(true_pos), bhat[true_pos[1]]))
cat(sprintf("  Negative region : %d voxels recovered, mean beta = %.3f",
length(neg_rec),
if (length(neg_rec) > 0) mean(bhat[neg_rec]) else NA))
cat(sprintf("  (true: %d voxels, beta = %.1f)\n",
length(true_neg), beta_true[j, true_neg[1]]))
cat(sprintf("  True positives  : %d / %d (%.0f%%)\n",
length(intersect(recovered, all_true)),
length(all_true),
100 * length(intersect(recovered, all_true)) / length(all_true)))
cat(sprintf("  False positives : %d\n",
length(setdiff(recovered, all_true))))
}
check_covariate(1, regions$b1_pos$vox, regions$b1_neg$vox)
check_covariate(2, regions$b2_pos$vox, regions$b2_neg$vox)
library(SIRA)
set.seed(42)
d1 <- d2 <- d3 <- 10L
V  <- d1 * d2 * d3
n  <- 200L
# Helper: linear voxel indices for a 3D box in column-major order
box <- function(i1r, i2r, i3r) {
as.integer(unlist(lapply(i3r, function(k)
unlist(lapply(i2r, function(j)
i1r + d1 * (j - 1L) + d1 * d2 * (k - 1L))))))
}
# --- True coefficient images -------------------------------------------
# Beta 1: positive cube near (1,1,1),  negative cube near (8,8,8)
# Beta 2: positive cube near (1,8,1),  negative cube near (8,1,8)
# Regions are fully separated (minimum gap >=4 voxels on every axis).
regions <- list(
b1_pos = list(vox = box(1:3, 1:3, 1:3), val =  2.5),
b1_neg = list(vox = box(8:10, 8:10, 8:10), val = -2.5),
b2_pos = list(vox = box(1:3, 8:10, 1:3), val =  2.0),
b2_neg = list(vox = box(8:10, 1:3, 8:10), val = -2.0)
)
beta_true <- matrix(0, nrow = 2, ncol = V)
beta_true[1, regions$b1_pos$vox] <-  2.5
beta_true[1, regions$b1_neg$vox] <- -2.5
beta_true[2, regions$b2_pos$vox] <-  2.0
beta_true[2, regions$b2_neg$vox] <- -2.0
# --- Generate data -------------------------------------------------------
X <- matrix(rnorm(n * 2), ncol = 2)
Z <- cbind(1, rnorm(n))
Y <- X %*% beta_true +
Z %*% matrix(rnorm(2 * V), nrow = 2) +
matrix(rnorm(n * V, sd = 2), nrow = n)
# --- Fit -----------------------------------------------------------------
fit <- sira(Y = Y, X = X, Z = Z,
d1 = d1, d2 = d2, d3 = d3,
lambda = 0.3, mu = 0.01)
print(fit)
# --- Diagnostics ---------------------------------------------------------
cat("\n=== Region-level diagnostics ===\n")
check_covariate <- function(j, true_pos, true_neg) {
bhat      <- fit$betahat[j, ]
recovered <- which(bhat != 0)
pos_rec   <- recovered[bhat[recovered] > 0]
neg_rec   <- recovered[bhat[recovered] < 0]
all_true  <- c(true_pos, true_neg)
cat(sprintf("\nCovariate %d:\n", j))
cat(sprintf("  Regions found   : %d  (expected 2)\n",
length(fit$region_list[[j]])))
cat(sprintf("  Positive region : %d voxels recovered, mean beta = %.3f",
length(pos_rec),
if (length(pos_rec) > 0) mean(bhat[pos_rec]) else NA))
cat(sprintf("  (true: %d voxels, beta = %.1f)\n",
length(true_pos), bhat[true_pos[1]]))
cat(sprintf("  Negative region : %d voxels recovered, mean beta = %.3f",
length(neg_rec),
if (length(neg_rec) > 0) mean(bhat[neg_rec]) else NA))
cat(sprintf("  (true: %d voxels, beta = %.1f)\n",
length(true_neg), beta_true[j, true_neg[1]]))
cat(sprintf("  True positives  : %d / %d (%.0f%%)\n",
length(intersect(recovered, all_true)),
length(all_true),
100 * length(intersect(recovered, all_true)) / length(all_true)))
cat(sprintf("  False positives : %d\n",
length(setdiff(recovered, all_true))))
}
check_covariate(1, regions$b1_pos$vox, regions$b1_neg$vox)
check_covariate(2, regions$b2_pos$vox, regions$b2_neg$vox)
